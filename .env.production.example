APP_NAME="Galvao Lavagem Tecnica"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://www.galvaolavagemtecnica.com.br
APP_TIMEZONE=America/Sao_Paulo

DB_HOST=localhost
DB_NAME=cpaneluser_galvao
DB_USER=cpaneluser_galvao
DB_PASS=troque-esta-senha
DB_CHARSET=utf8mb4

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5

BREVO_ENABLED=false
BREVO_API_KEY=
BREVO_FROM_EMAIL=contato@galvaolavagemtecnica.com.br
BREVO_FROM_NAME="Galvão Lavagem Técnica"
LEAD_NOTIFICATION_EMAIL=

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

UPLOAD_MAX_MB=10
UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,image/webp,image/gif
STORAGE_DISK=local
STORAGE_PUBLIC_PROXY=/admin/api/image.php

SESSION_TIMEOUT_SECONDS=3600
REMEMBER_ME_DAYS=30
CSRF_ROTATE_SECONDS=7200
SECURITY_RATE_LIMIT_ENABLED=true

AI_CACHE_ENABLED=true
AI_IMAGE_COOLDOWN_SECONDS=45
AI_IMAGE_PRE_QUIZ_LIMIT=1
AI_IMAGE_POST_QUIZ_LIMIT=3

BACKUP_RETENTION_DAILY=14
BACKUP_RETENTION_WEEKLY=8
