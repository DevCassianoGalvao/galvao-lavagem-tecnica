APP_NAME="Galvao Lavagem Tecnica"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/galvao-lavagem-tecnica
APP_TIMEZONE=America/Sao_Paulo

DB_HOST=127.0.0.1
DB_NAME=galvao_lavagem_tecnica
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

ADMIN_EMAIL=admin@galvao.local
ADMIN_PASSWORD=Admin@12345
CPANEL_INSTALL_KEY=troque-por-uma-chave-forte

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

UPLOAD_MAX_MB=10
UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,image/webp,image/gif
STORAGE_DISK=local
STORAGE_PUBLIC_PROXY=/admin/api/image.php

SESSION_TIMEOUT_SECONDS=3600
REMEMBER_ME_DAYS=30
CSRF_ROTATE_SECONDS=7200
SECURITY_RATE_LIMIT_ENABLED=true

AI_CACHE_ENABLED=true
AI_IMAGE_COOLDOWN_SECONDS=45
AI_IMAGE_PRE_QUIZ_LIMIT=1
AI_IMAGE_POST_QUIZ_LIMIT=3

BACKUP_RETENTION_DAILY=14
BACKUP_RETENTION_WEEKLY=8
